{
  "expo": {
    "name": "Copy History",
    "slug": "copyhistory",
    "version": "2.24",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.markutilitylabs.copyhistory",
      "buildNumber": "1",
      "infoPlist": {
        "CFBundleDisplayName": "Copy History",
        "ITSAppUsesNonExemptEncryption": false,
        "UIUserInterfaceStyle": "Automatic",
        "CFBundleLocalizations": [
          "en",
          "ar"
        ],
        "CFBundleDevelopmentRegion": "en"
      },
      "userInterfaceStyle": "automatic"
    },
    "android": {
      "package": "com.markutilitylabs.copyhistory",
      "versionCode": 24,
      "adaptiveIcon": {
        "backgroundColor": "#1d4ed8",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/withCopyToClipboardExtension",
      "./plugins/withActionExtension",
      "./plugins/withKeyboardExtension",
      "./plugins/withWidgetExtension",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1d4ed8",
          "image": "./assets/splash-icon.png",
          "imageWidth": 240
        }
      ],
      "expo-font",
      "expo-localization"
    ],
    "locales": {
      "en": "./locales/en.json",
      "ar": "./locales/ar.json"
    }
  }
}
